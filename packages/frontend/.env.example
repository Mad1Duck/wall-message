# ── Auth (required) ──────────────────────────────────────────────────────────
# Clerk publishable key — get it from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend API (required) ────────────────────────────────────────────────────
# URL of the backend server (packages/backend)
VITE_API_URL=http://localhost:3001

# ── Optional ──────────────────────────────────────────────────────────────────
# Browser tab title override
VITE_APP_TITLE=Titipkan

# Password to protect the inbox page (defaults to "demo" if not set)
VITE_OWNER_PASSWORD=your_inbox_password
